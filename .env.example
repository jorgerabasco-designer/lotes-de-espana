# ---------- VARIABLES DE ENTORNO ----------
# Copia este archivo a `.env` (sin la palabra example) y rellena los valores.
# En Netlify hay que añadirlas en: Site settings → Environment variables.

# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# Gemini · Google AI Studio (https://aistudio.google.com/app/apikey)
# IMPORTANTE: SOLO se usa en la función serverless de Netlify, nunca en el cliente.
GEMINI_API_KEY=AIza...

# Modelo de generación de imágenes (no cambiar a menos que sepas lo que haces)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# Supabase Service Role (solo en Netlify, para guardar imágenes generadas en Storage).
# Project Settings → API → service_role key. NUNCA la pongas en el frontend.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...
